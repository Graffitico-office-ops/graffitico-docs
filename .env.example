# ─── Pipedrive ───────────────────────────────────────────────────────────────
PIPEDRIVE_API_TOKEN=your_pipedrive_api_token_here
PIPEDRIVE_DOMAIN=graffitico   # the subdomain of graffitico.pipedrive.com

# ─── Google OAuth ────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REFRESH_TOKEN=     # filled in after running: npm run auth

# ─── Google Drive ────────────────────────────────────────────────────────────
# The ID of the GraffitiCo shared Drive folder where PDFs will be saved.
# Get it from the URL when you open the folder: drive.google.com/drive/folders/FOLDER_ID
GOOGLE_DRIVE_FOLDER_ID=your_shared_folder_id_here

# ─── Output ──────────────────────────────────────────────────────────────────
OUTPUT_DIR=./output   # local backup folder for generated PDFs
